{
  "name": "Apex-Leads Outbound Callback (Minimal)",
  "flow": [
    {
      "id": 1,
      "module": "webhooks:customWebhook",
      "version": 1,
      "parameters": {
        "hook": 1,
        "maxResults": 1
      },
      "mapper": {},
      "metadata": {
        "designer": {
          "x": 0,
          "y": 0
        },
        "restore": {
          "parameters": {
            "hook": {
              "label": "Apex Leads Outbound Minimal"
            }
          }
        }
      }
    },
    {
      "id": 2,
      "module": "webhooks:webhookResponse",
      "version": 1,
      "parameters": {},
      "mapper": {
        "status": 200,
        "headers": [
          {
            "name": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": "{\"ok\":true,\"leadId\":\"{{1.leadId}}\",\"name\":\"{{1.name}}\",\"phone\":\"{{1.phone}}\"}"
      },
      "metadata": {
        "designer": {
          "x": 300,
          "y": 0
        }
      }
    }
  ],
  "metadata": {
    "version": 1,
    "scenario": {
      "roundtrips": 1,
      "maxErrors": 3,
      "autoCommit": true,
      "autoCommitTriggerLast": true,
      "sequential": false,
      "slots": null,
      "confidential": false,
      "dataloss": false,
      "dlq": false,
      "freshVariables": false
    },
    "designer": {
      "orphans": []
    },
    "zone": "eu1.make.com"
  },
  "subflows": []
}
